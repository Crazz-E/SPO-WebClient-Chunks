{
  "name": "spo-chunks",
  "version": "1.0.0",
  "description": "Standalone terrain chunk generator for Starpeace Online — generates isometric map chunks and uploads to Cloudflare R2",
  "main": "dist/cli.js",
  "bin": {
    "spo-chunks": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsc && node dist/cli.js",
    "clean": "rm -rf dist"
  },
  "keywords": ["starpeace", "terrain", "chunks", "cloudflare", "r2"],
  "author": "Crazz-E",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "sharp": "^0.34.5",
    "7zip-min": "^2.1.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "commander": "^13.0.0",
    "cli-progress": "^3.12.0",
    "chalk": "^4.1.2",
    "cheerio": "^1.1.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^22.0.0",
    "@types/cli-progress": "^3.11.6",
    "@types/node-fetch": "^2.6.12"
  }
}
